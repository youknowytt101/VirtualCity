# ===== Windows =====
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===== Houdini =====
# 缓存和模拟数据（体积大，不提交）
Houdini/PDG_Output/
*.sim
*.simdata
*.bgeo.sc
*.bgeo
*.pc
*.geo
*.vdb
*.rat

# Houdini 备份文件
*.hip.bak
*.hip[0-9]
*.hiplc.bak
*.hipnc.bak
backup/

# Houdini 临时目录
houdini.env
houdini[0-9]*/

# ===== UE5 =====
# UE5 编译和缓存（体积极大，不提交）
UE5/*/Binaries/
UE5/*/Build/
UE5/*/DerivedDataCache/
UE5/*/Intermediate/
UE5/*/Saved/
UE5/*/.vs/
UE5/*/Plugins/*/Binaries/
UE5/*/Plugins/*/Intermediate/

# ===== 大型导出文件 =====
# FBX / OBJ / ABC 先不提交，体积可能很大
# 如需提交，删掉对应行
Houdini/Export/*.fbx
Houdini/Export/*.obj
Houdini/Export/*.abc
Houdini/Export/*.usd
Houdini/Export/*.usdc
Houdini/Export/*.usdz

# ===== GIS 处理输出 =====
# GeoJSON 和处理过的 GIS 文件可能很大
RawData/GIS_Processed/*.geojson
RawData/GIS_Processed/*.shp
RawData/GIS_Processed/*.tif
RawData/GIS_Processed/*.tiff
RawData/DEM/*.tif
RawData/DEM/*.tiff
RawData/DEM/*.img
RawData/DEM/*.hgt

# ===== 临时结果文件 =====
Config/_*.txt
Config/_*.py
Config/houdini_build_status.json
Reports/model_qa/*.json

# ===== 数据精炼管线缓存（体积大，不提交）=====
RawData/_downloads/
RawData/_cleaned/
RawData/_houdini_ready/

# ===== 大型测试数据（>5MB，不提交）=====
RawData/Overture/*stress_test*
RawData/OSM/*stress_test*
RawData/DEM/*stress_test*

# ===== Python =====
__pycache__/
*.py[cod]
*.pyo
.env
.venv/
venv/

# ===== 编辑器 =====
.vscode/
*.swp
*.swo
*~

# ===== 不排除以下内容（明确保留）=====
# .windsurf/workflows/ - 工作流文件
# RawData/OSM/*.osm - OSM 数据文件（通常 <10MB）
# Houdini/Hip/*.hip - Hip 工程文件
# 项目管理/ - 所有项目文档
# Config/ - 所有配置文件
